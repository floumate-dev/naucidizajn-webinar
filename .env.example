# ──────────────────────────────────────────────────────────────────────────
# Vercel Environment Variables — za /api/signup.js (referral serverless funkcija)
# Kopiraj u Vercel → Project Settings → Environment Variables (NE commituj prave vrednosti).
# ──────────────────────────────────────────────────────────────────────────

# Supabase (Project Settings → API)
SUPABASE_URL=https://xxxxxxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=          # service_role key — SAMO server-side, NIKAD u frontend

# Dashboard share link / dashboard base
DASHBOARD_BASE_URL=https://app.naucidizajn.com

# ──────────────────────────────────────────────────────────────────────────
# OPCIONO — samo ako /api/signup radi i Kit (tagId u body-ju). U JUL-2026 WEBINAR
# FLOW-U Kit ide preko Make-a, pa thank-you NE šalje tagId => ovo nije potrebno.
# (Ostaje za eventualni giveaway/Kit-direct mod.)
# ──────────────────────────────────────────────────────────────────────────
CONVERTKIT_API_SECRET=              # Kit V4 API key (Settings → Advanced)
CONVERTKIT_WINNER_TAG_ID=           # opciono — tag kad referrer dostigne prag
REWARD_THRESHOLD=5
WEBINAR_LANDING_URL=https://www.naucidizajn.com/ai-dizajnira-ti-zaradjujes-webinar-jul-2026

# ──────────────────────────────────────────────────────────────────────────
# AEvent REST API token (JWT) — NIJE za /api/signup. Treba samo POSLE webinara
# za povlačenje attendance/watch-time (vidi docs/AEVENT.md). Drži kao tajnu.
# ──────────────────────────────────────────────────────────────────────────
AEVENT_API_TOKEN=                   # Bearer JWT, nalog 42253777 (registrants/timelines read)
